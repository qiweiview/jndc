<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.view.jndc.manage.dao.jndc_server_app.JndcServerAppDao" >

    <resultMap type="com.view.jndc.manage.model.jndc_server_app.d_o.JndcServerAppDO" id="JndcServerAppMap" >
                <id property="id" column="id" />
                <result property="bindHost" column="bind_host" />
                <result property="bindPort" column="bind_port" />
                <result property="bindStatus" column="bind_status" />
                <result property="createTime" column="create_time" />
                <result property="serverId" column="server_id" />
                <result property="sourceClientId" column="source_client_id" />
                <result property="sourceServiceId" column="source_service_id" />

                <result property="bindType" column="bind_type" />
                <result property="metaData" column="meta_data" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
            bind_host,
            bind_port,
            bind_status,
            bind_type,
            meta_data,
            create_time,
            id,
            server_id,
            source_client_id,
            source_service_id
    </sql>

    <update id="updateStatusByServiceId">
        update jndc_server_app
        <set>
            bind_status = #{status}
        </set>
        where source_service_id = #{serviceId}
    </update>


    <select id="listPage" resultMap="JndcServerAppMap"
            parameterType="com.view.jndc.manage.model.jndc_server_app.d_o.JndcServerAppDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_server_app
        <where>
            <if test="do.serverId != null">
                and server_id = #{do.serverId}
            </if>
        </where>
    </select>

    <select id="list" resultMap="JndcServerAppMap"
            parameterType="com.view.jndc.manage.model.jndc_server_app.d_o.JndcServerAppDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_server_app
    </select>

    <select id="getByServiceId" resultType="com.view.jndc.manage.model.jndc_server_app.d_o.JndcServerAppDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_server_app
        where source_service_id = #{serviceId}
    </select>

    <select id="listByBindPort" resultType="com.view.jndc.manage.model.jndc_server_app.d_o.JndcServerAppDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_server_app
        where bind_port = #{bindPort}
    </select>

</mapper>
