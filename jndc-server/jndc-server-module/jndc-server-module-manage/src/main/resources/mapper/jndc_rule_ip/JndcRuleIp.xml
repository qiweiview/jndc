<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.view.jndc.manage.dao.jndc_rule_ip.JndcRuleIpDao">

    <resultMap type="com.view.jndc.manage.model.jndc_rule_ip.d_o.JndcRuleIpDO" id="JndcRuleIpMap">
        <id property="id" column="id"/>
        <result property="belongId" column="belong_id"/>
        <result property="createTime" column="create_time"/>
        <result property="ipAddress" column="ip_address"/>
        <result property="ruleName" column="rule_name"/>
        <result property="ruleStatus" column="rule_status"/>
        <result property="ruleType" column="rule_type"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        belong_id
        ,
            create_time,
            id,
            ip_address,
            rule_name,
            rule_status,
            rule_type,
            update_time
    </sql>


    <select id="listPage" resultMap="JndcRuleIpMap"
            parameterType="com.view.jndc.manage.model.jndc_rule_ip.d_o.JndcRuleIpDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_rule_ip
    </select>

    <select id="list" resultMap="JndcRuleIpMap"
            parameterType="com.view.jndc.manage.model.jndc_rule_ip.d_o.JndcRuleIpDO">
        select
        <include refid="Base_Column_List"></include>
        from
        jndc_rule_ip
    </select>

</mapper>
