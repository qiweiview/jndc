# ============================================================
#  JNDC Server — 环境变量配置
#
#  此文件在启动时由 jndc.sh 自动加载。
#  所有项均为可选，未设置则使用脚本内置默认值。
#  systemd 部署时也会通过 EnvironmentFile 加载此文件。
#
#  注意: 每行一个 KEY=VALUE，值中不要有引号，行尾不要有注释。
# ============================================================

# ---- Java 环境 ----
# JAVA_HOME=/usr/local/jdk8

# ---- 运行模式 ----
# prod = 生产模式 (默认，部署到 /data/app/ 时自动启用)
# dev  = 开发模式 (内存更小，无 GC 日志)
# JNDC_MODE=prod

# ---- JVM 内存 ----
# JVM_XMS=-Xms512m
# JVM_XMX=-Xmx1024m
# JVM_METASPACE=-XX:MaxMetaspaceSize=256m

# ---- GC 日志 (仅 prod 模式默认开启) ----
# GC_LOG=true

# ---- 优雅停机超时 (秒) ----
# SHUTDOWN_TIMEOUT=30

# ---- 自定义 JVM 参数 ----
# JVM_OPTS=-Dfile.encoding=UTF-8 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/data/app/jndc-server/logs/heapdump.hprof
